{
  "name": "zest",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun run --hot backend/index.ts",
    "output": "bun build ./backend/index.ts --outdir ./dist --target bun --bundle --external drizzle-orm --external drizzle-kit",
    "build": "sh build_frontend.sh",
    "db:push": "bunx drizzle-kit push",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate"
  },
  "dependencies": {
    "@libsql/client": "^0.17.4",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11"
  }
}
